---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import TrackGrid from "../components/TrackGrid.astro";
import TrackGridHeader from "../components/TrackGridHeader.astro";
import Preloader from "../components/Preloader.astro";

const allTracks = await getCollection("tracks");
const tracksTotal = allTracks.length;
const title = "i.am.strong — All Tracks";
---
<BaseLayout title={title}>
  <Preloader />
  <TrackGridHeader tracksTotal={tracksTotal} />
  <TrackGrid tracks={allTracks} />
</BaseLayout>
<script src="../scripts/index.js"></script>
